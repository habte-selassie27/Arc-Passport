# Foundry deploy env (NEVER commit a real .env — only use this template)

# Arc network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_BLOCKCHAIN_ENV=ARC-TESTNET

# Deployed contract addresses (populated by Deploy.s.sol)
ATTESTATION_REGISTRY_ADDRESS=
SCHEMA_REGISTRY_ADDRESS=
PASSPORT_VERIFIER_ADDRESS=
PASSPORT_VERIFIER_PROXY_ADDRESS=

# Protocol admin multisig (receives DEFAULT_ADMIN_ROLE + UPGRADER_ROLE + PAUSER_ROLE)
ARC_MULTISIG_ADDRESS=

# Testnet deployer key (use a fresh, unfunded key — never reuse a mainnet key here)
DEPLOYER_PRIVATE_KEY=

# Block explorer verification (if/when arcscan supports it)
ETHERSCAN_API_KEY=
